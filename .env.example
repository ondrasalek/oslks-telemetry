# ==========================================
# OSLKS Telemetry - Environment Configuration
# ==========================================

# --- 1. Database (TimescaleDB) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=oslks_telemetry
# Internal Docker network connection string
DATABASE_URL=postgres://postgres:postgres@db:5432/oslks_telemetry

# --- 2. Backend (Rust Collector) ---
HOST=0.0.0.0
PORT=8080
# Secret for session ID generation (use a long random string)
SESSION_SECRET=change-this-to-a-secure-random-string
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com,https://radar.example.com
# Log level (info, debug, trace)
RUST_LOG=oslks_telemetry=info,tower_http=info

# --- 3. GeoIP (Optional) ---
# Path to MaxMind GeoLite2-City.mmdb inside the container
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# --- 4. SMTP Settings (Optional) ---
# Used for welcome emails and system notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secure-password
SMTP_FROM_EMAIL=no-reply@radar.example.com
SMTP_FROM_NAME=OSLKS Radar

# --- 5. Frontend (React Dashboard) ---
# Public URL where the dashboard is hosted
VITE_APP_URL=https://radar.example.com
# Internal URL for Nginx proxy to reach the collector
COLLECTOR_INTERNAL_URL=http://oslks-collector:8080

# --- 6. Analytics (Optional) ---
# Self-tracking configuration
VITE_OSLKS_COLLECTOR_URL=https://telemetry.example.com
VITE_OSLKS_WEBSITE_ID=
