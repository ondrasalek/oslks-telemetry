# OSLKS Telemetry - Backend Local Development Override
# This file is for running the backend standalone (without Docker)

# PostgreSQL connection string for local DB
DATABASE_URL=postgres://postgres:postgres@localhost:5432/oslks_telemetry?sslmode=disable

# Session secret (long random string)
SESSION_SECRET=local_dev_secret_key_change_me

# Bind address
HOST=127.0.0.1
PORT=8080

# Allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging level
RUST_LOG=oslks_telemetry=debug,tower_http=debug

# Optional: Path to MaxMind GeoLite2-City.mmdb
# GEOIP_DB_PATH=./src/data/GeoLite2-City.mmdb