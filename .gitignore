# --- General ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Environment Variables ---
.env
.env.local
.env.*.local
# Keep .env.example tracked!
!.env.example

# --- Rust (Backend) ---
# Ignore build artifacts in any depth (backend/target, root/target)
**/target/
**/*.rs.bk

# ⚠️ NOTE: Cargo.lock should NOT be ignored for applications.
# It ensures reproducible builds in production.

# --- Node.js (Tailwind/Tools) ---
**/node_modules/
**/.npm/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*