:80 {
    root * /srv

    encode gzip

    # API proxy
    handle /api/* {
        reverse_proxy backend:8080 {
            header_down -WWW-Authenticate
        }
    }

    # Stealth telemetry collector (strip /assets/v1 prefix before proxying)
    handle /assets/v1/* {
        uri strip_prefix /assets/v1
        reverse_proxy backend:8080 {
            header_down -WWW-Authenticate
        }
    }

    # Serve SPA with fallback to index.html
    handle {
        try_files {path} /index.html
        file_server
    }
}
